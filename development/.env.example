# ── server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
RUST_LOG=swingbot=info,tower_http=debug

# ── database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://swingbot:swingbot@localhost:5432/swingbot

# ── telegram (required from M8) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret for validating webhook requests (any random string works)
TELEGRAM_WEBHOOK_SECRET=

# ── market data ───────────────────────────────────────────────────────────────
# Polygon.io — required for equities (M3+); free tier covers daily candles
POLYGON_API_KEY=
# CoinGecko — required for crypto (M3+); free public API, key is optional
COINGECKO_API_KEY=
# Alpha Vantage — optional fallback / fundamentals data
ALPHA_VANTAGE_API_KEY=

# ── trading ───────────────────────────────────────────────────────────────────
# paper | live_manual
TRADING_MODE=paper
# Set to false; Trade Republic does not support short selling
ALLOW_SHORT_SIGNALS=false
# Total account equity in ACCOUNT_CURRENCY (used for position sizing)
ACCOUNT_SIZE=10000
ACCOUNT_CURRENCY=EUR
# Fraction of account risked per trade, e.g. 1.0 = 1%
RISK_PER_TRADE_PCT=1.0
# Minimum reward-to-risk ratio to accept a signal
MIN_RISK_REWARD=3.0
# Maximum number of simultaneously open trades
MAX_OPEN_TRADES=5
# Maximum total open risk across all trades, e.g. 5.0 = 5%
MAX_TOTAL_OPEN_RISK_PCT=5.0
# Whether the broker supports fractional shares (affects quantity rounding)
FRACTIONAL_SHARES=true
# Minimum signal score (0–100) to forward to Telegram
SCORE_THRESHOLD=60

# ── scanner ───────────────────────────────────────────────────────────────────
# Minutes after NYSE open to suppress equity notifications (opening volatility)
SCAN_BLACKOUT_OPEN_MINS=30
# Minutes before NYSE close to suppress equity notifications
SCAN_BLACKOUT_CLOSE_MINS=30
# Minimum average daily volume in USD ($1M default for liquidity)
MIN_ADV_USD=1000000
# Minimum share price to consider (filters out penny stocks)
MIN_SYMBOL_PRICE=1.0

# ── scale-out ─────────────────────────────────────────────────────────────────
# Whether to offer partial profit taking at 1R (M9)
SCALE_OUT_ENABLED=true

# ── watchdog ──────────────────────────────────────────────────────────────────
# How often the open-trade monitor polls (seconds)
WATCHDOG_CHECK_SECS=120
# Age at which a trade without a price update is considered stale (seconds)
WATCHDOG_STALE_SECS=300
